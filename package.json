{
  "name": "nutcolor",
  "version": "0.0.0",
  "description": "Chroma relative to the gamut shell (cusp) in OKLCH/LCH. Dependency-free, LUT-backed.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/nutcolor.umd.cjs",
  "module": "./dist/nutcolor.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nutcolor.js",
      "require": "./dist/nutcolor.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build:luts": "tsx scripts/build-luts.ts",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:demo": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "culori": "^4.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.0"
  }
}
