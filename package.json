{
  "name": "nutelch",
  "version": "0.0.0",
  "description": "Chroma relative to the gamut shell (cusp) in OKLCH/LCH. Dependency-free, LUT-backed.",
  "type": "module",
  "author": "David Aerne <meodai@gmail.com>",
  "license": "MIT",
  "homepage": "https://meodai.github.io/nutelch/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meodai/nutelch.git"
  },
  "bugs": {
    "url": "https://github.com/meodai/nutelch/issues"
  },
  "keywords": [
    "oklch",
    "lch",
    "color",
    "color-space",
    "gamut",
    "chroma",
    "cusp",
    "saturation",
    "okhsl",
    "css-color"
  ],
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/nutelch.umd.cjs",
  "module": "./dist/nutelch.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nutelch.js",
      "require": "./dist/nutelch.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build:luts": "tsx scripts/build-luts.ts",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:demo": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build:lib"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "culori": "^4.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.0"
  }
}
